service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helpers
    function isApproved() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }
    
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        // User can update their own profile EXCEPT for role/status/limits/permissions
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'role', 'limits', 'permissions'])) ||
        // Admin can update anything
        isAdmin()
      );
    }
    
    // Groups
    match /groups/{groupId} {
      function can(perm) {
        return get(/databases/$(database)/documents/groups/$(groupId)).data.roles[request.auth.uid] == 'owner' ||
               (exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)) && 
                get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.permissions[perm] == true);
      }

      allow read: if request.auth != null && (isApproved() || isAdmin());
      
      allow create: if request.auth != null && isApproved()
                    && request.resource.data.ownerId == request.auth.uid;
      
      allow update: if request.auth != null && (
        // 1. Owner has full access
        (resource.data.roles[request.auth.uid] == 'owner' && isApproved()) ||
        
        // 2. Member with specific permissions
        (request.auth.uid in resource.data.userIds && isApproved() && (
          // Add/Edit member names
          (can('canAddMembers') && 
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'updatedAt', 'updatedBy']) &&
           request.resource.data.members.size() >= resource.data.members.size()) ||
          
          // Remove member names or users
          (can('canRemoveMembers') && 
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'userIds', 'roles', 'updatedAt', 'updatedBy']))
        )) ||

        // 3. Member updating presence or leaving
        (request.auth.uid in resource.data.userIds && (
          // Presence update
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeen', 'updatedAt', 'updatedBy']) ||
          // Leaving (self-removal)
          (request.resource.data.userIds.size() == resource.data.userIds.size() - 1 &&
           !request.resource.data.userIds.hasAny([request.auth.uid]))
        )) ||

        // 4. Joining (self-addition)
        (request.resource.data.userIds.hasAll(resource.data.userIds) && 
         request.resource.data.userIds.hasAll([request.auth.uid]) && isApproved())
      );
      
      allow delete: if request.auth != null && resource.data.roles[request.auth.uid] == 'owner' && isApproved();
      
      // Member permissions subcollection
      match /members/{userId} {
        allow read: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.userIds ||
          request.auth.uid in getAfter(/databases/$(database)/documents/groups/$(groupId)).data.userIds
        );
        allow write: if request.auth != null && (
          // 1. User is the owner of the group (works for new and existing groups)
          (getAfter(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid && isApproved()) ||
          (get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid && isApproved()) ||
          // 2. User is creating their own record as a viewer
          (request.auth.uid == userId && request.resource.data.role == 'viewer')
        );
      }

      // Transactions subcollection
      match /transactions/{txId} {
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.userIds;
        
        allow create: if request.auth != null && isApproved() && can('canAddExpense');
        
        allow update: if request.auth != null && isApproved() && (
          can('canEditOthersExpense') ||
          (request.auth.uid == resource.data.createdBy && can('canEditOwnExpense')) ||
          (request.auth.uid != resource.data.createdBy && can('canEditOthersExpense'))
        );

        allow delete: if request.auth != null && isApproved() && (
          (request.auth.uid == resource.data.createdBy && can('canDeleteOwnExpense')) ||
          (request.auth.uid != resource.data.createdBy && can('canDeleteOthersExpense'))
        );
      }
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.targetUserId;
      allow create: if request.auth != null && isApproved();
    }
  }
}
