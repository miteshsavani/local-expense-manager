rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile: only the user can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Groups: Metadata is readable by any signed-in user (to allow finding by share code)
    // but actual transactions are protected below.
    match /groups/{groupId} {
      allow read: if request.auth != null;
      
      // Allow creation if the creator sets themselves as owner
      allow create: if request.auth != null 
                    && request.resource.data.ownerId == request.auth.uid;
      
      // Allow update if member, OR if joining (adding own UID to userIds)
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.userIds || 
        (request.resource.data.userIds.hasAll(resource.data.userIds) && 
         request.resource.data.userIds.hasAll([request.auth.uid]))
      );
      
      allow delete: if request.auth != null && resource.data.roles[request.auth.uid] == 'owner';
      
      // Transactions subcollection
      match /transactions/{txId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.userIds;
      }
    }

    // Notifications: Activity feed for users
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.targetUserId;
      allow create: if request.auth != null; // Actor creates for others
    }
  }
}
