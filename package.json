{
  "name": "local-expense-manager",
  "version": "1.0.0",
  "description": "A lightweight, fully client-side expense sharing application built using pure HTML, CSS, and JavaScript in a single file. This app helps users manage group expenses, track balances, and settle debts—similar to Splitwise, but without any backend or external dependencies.",
  "main": "service-worker.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "node scripts/build-chokidar.js",
    "dev": "node scripts/build-chokidar.js --watch",
    "serve": "node scripts/serve.js",
    "start": "concurrently \"npm run dev\" \"npm run serve\"",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "prepare": "husky",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miteshsavani/local-expense-manager.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/miteshsavani/local-expense-manager/issues"
  },
  "homepage": "https://github.com/miteshsavani/local-expense-manager#readme",
  "devDependencies": {
    "chokidar": "^5.0.0",
    "clean-css": "^5.3.3",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "express": "^5.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "ws": "^8.20.0"
  },
  "dependencies": {}
}
